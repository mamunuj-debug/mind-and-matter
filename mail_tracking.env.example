# Copy this file to a private env file and replace placeholders.
# Do not commit real passwords or API tokens.

# -----------------------------
# Mailbox settings
# -----------------------------
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USERNAME=mamunuj@gmail.com
EMAIL_PASSWORD=your-google-app-password
EMAIL_FOLDER=INBOX
EMAIL_USE_SSL=true
POLL_SECONDS=30
# latest = ignore old mails on first start, all = process old mails too
EMAIL_STARTUP_MODE=latest
SUMMARY_BODY_CHARS=180
STATE_FILE=.mail_tracking_state.json
LOG_LEVEL=INFO

# -----------------------------
# WhatsApp provider
# Choose one: meta or twilio
# -----------------------------
WHATSAPP_PROVIDER=twilio
WA_TO_NUMBER=whatsapp:+918145269032

# -----------------------------
# WhatsApp Cloud API (Meta)
# -----------------------------
WA_PHONE_NUMBER_ID=your_meta_phone_number_id
WA_ACCESS_TOKEN=your_meta_access_token

# -----------------------------
# Twilio WhatsApp API
# Use whatsapp:+<countrycode><number>
# Example: whatsapp:+14155238886
# -----------------------------
WA_ACCOUNT_SID=your_twilio_account_sid
WA_AUTH_TOKEN=your_twilio_auth_token
WA_FROM_NUMBER=whatsapp:+14155238886
# For your number, keep the same value as WA_TO_NUMBER above.
# WA_TO_NUMBER=whatsapp:+918145269032
