[Unit]
Description=WhatsApp mail tracking notifier
After=network.target

[Service]
Type=simple
WorkingDirectory=/path/to/GHCP_WW17
EnvironmentFile=/path/to/GHCP_WW17/.mail_tracking.env
ExecStart=/usr/bin/python3 /path/to/GHCP_WW17/mail_tracking.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
